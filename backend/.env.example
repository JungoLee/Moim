# Moim 백엔드 환경변수 — 이 파일을 .env 로 복사해서 채우세요. (.env 는 커밋 금지)
PORT=4000

# 로컬 MongoDB 또는 MongoDB Atlas 연결 문자열
MONGODB_URI=mongodb://127.0.0.1:27017/moim

# JWT 서명 키 — 길고 무작위한 문자열로 교체. 한 번 정하면 고정 유지(바꾸면 모든 로그인 무효화)
JWT_SECRET=change-me-to-a-long-random-string

# Google Cloud Console > API 및 서비스 > 사용자 인증 정보에서 OAuth 2.0 클라이언트 ID 생성
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# 아래 콜백 URL을 OAuth 클라이언트의 "승인된 리디렉션 URI"에 그대로 등록해야 함
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# 프론트엔드 주소 (CORS 허용 + 로그인 후 리디렉션 대상)
FRONTEND_URL=http://localhost:3000

# 이메일 코드 로그인 발송용 SMTP (선택 — 미설정 시 발송 대신 서버 콘솔에 코드 출력)
# Gmail 사용 시: 구글 계정 → 보안 → 2단계 인증 → 앱 비밀번호 발급 → SMTP_PASS 에 입력
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# 보내는 사람 표시 (선택, 기본 SMTP_USER)
SMTP_FROM=
